# Solana devnet RPC. Use a dedicated provider endpoint in production.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Optional override. Defaults to the address embedded in the checked-in IDL.
NEXT_PUBLIC_TALKN_DO_PROGRAM_ID=9CLYHqqCBfDsuDrwooBbzV8FuvVzsZwadUCZ2NLWSURE

# Server-only Pinata credentials. Never prefix the JWT with NEXT_PUBLIC_.
PINATA_JWT=replace_with_your_pinata_jwt
PINATA_GATEWAY_URL=https://your-gateway.mypinata.cloud
